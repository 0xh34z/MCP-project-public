  "panels": [
    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "text" },
            "footer": { "reducers": [] },
            "inspect": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 11, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "cellHeight": "sm",
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Time" }]
      },
      "pluginVersion": "12.4.1",
      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
          "format": "table",
          "rawSql": "SELECT\n  tul.created_at AS \"Time\",\n  u.username AS \"User\",\n  tul.server_name AS \"Server\",\n  tul.tool_name AS \"Tool\",\n  tul.status AS \"Status\",\n  tul.duration_ms AS \"Duration (ms)\",\n  LEFT(REPLACE(j.prompt, '\\n', ' '), 400) AS \"Prompt\",\n  LEFT(tul.arguments_json, 1200) AS \"Arguments\",\n  LEFT(COALESCE(tul.output_text, tul.error_text, ''), 2500) AS \"Output/Error\"\nFROM tool_usage_logs tul\nJOIN users u ON u.id = tul.user_id\nJOIN jobs j ON j.id = tul.job_id\nWHERE $__timeFilter(tul.created_at)\nORDER BY tul.created_at DESC\nLIMIT 200",
          "refId": "A"
        }
      ],
      "title": "Recent Tool Executions (Who, What, Prompt, Output)",
      "type": "table"
    },
    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "id": 2,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "pluginVersion": "12.4.1",
      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
          "format": "time_series",
          "rawSql": "SELECT\n  $__timeGroupAlias(tul.created_at, '5m'),\n  tul.tool_name AS metric,\n  COUNT(*) AS value\nFROM tool_usage_logs tul\nWHERE $__timeFilter(tul.created_at)\nGROUP BY 1, 2\nORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Tool Calls Over Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "orange", "value": 70 }, { "color": "green", "value": 90 }] }, "unit": "percent" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 11 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "12.4.1",
      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
          "format": "table",
          "rawSql": "SELECT\n  ROUND(100 * SUM(CASE WHEN tul.success = 1 THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0), 2) AS value\nFROM tool_usage_logs tul\nWHERE $__timeFilter(tul.created_at)",
          "refId": "A"
        }
      ],
      "title": "Tool Success Rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "text" },
            "footer": { "reducers": [] },
            "inspect": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 11 },
      "id": 4,
      "options": {
        "cellHeight": "sm",
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Errors" }]
      },
      "pluginVersion": "12.4.1",
      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
          "format": "table",
          "rawSql": "SELECT\n  tul.tool_name AS \"Tool\",\n  COUNT(*) AS \"Errors\"\nFROM tool_usage_logs tul\nWHERE $__timeFilter(tul.created_at)\n  AND tul.success = 0\nGROUP BY tul.tool_name\nORDER BY COUNT(*) DESC\nLIMIT 10",
          "refId": "A"
        }
      ],
      "title": "Top Failing Tools",
      "type": "table"
    },
    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
        "defaults": {
