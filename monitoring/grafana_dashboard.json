          "format": "table",
          "rawSql": "SELECT\n  ROUND(100 * SUM(CASE WHEN cm.reaction = 'up' THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0), 2) AS value\nFROM chat_message_feedback cm\nWHERE $__timeFilter(cm.created_at)",
