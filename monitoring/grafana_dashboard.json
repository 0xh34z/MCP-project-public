      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 19 },
      "id": 5,
      "options": {
        "cellHeight": "sm",
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Time" }]
      },
      "pluginVersion": "12.4.1",
      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
          "format": "table",
          "rawSql": "SELECT\n  tul.created_at AS \"Time\",\n  u.username AS \"User\",\n  tul.server_name AS \"Server\",\n  tul.tool_name AS \"Tool\",\n  LEFT(REPLACE(j.prompt, '\\n', ' '), 300) AS \"Prompt\",\n  LEFT(COALESCE(tul.error_text, tul.output_text, ''), 3500) AS \"Error/Output Details\"\nFROM tool_usage_logs tul\nJOIN users u ON u.id = tul.user_id\nJOIN jobs j ON j.id = tul.job_id\nWHERE $__timeFilter(tul.created_at)\n  AND tul.success = 0\nORDER BY tul.created_at DESC\nLIMIT 100",
          "refId": "A"
        }
      ],
      "title": "Failed Tool Calls Detail",
      "type": "table"
    },
    {
      "datasource": { "type": "mysql", "uid": "${DS_MYSQL}" },
      "fieldConfig": {
